# Database
DATABASE_URL=postgresql+asyncpg://unefy:unefy@localhost:5432/unefy

# Redis
REDIS_URL=redis://localhost:6379/0

# Deployment
DEPLOYMENT_MODE=self-hosted

# Security
INTERNAL_API_SECRET=change-me-in-production
SESSION_SECRET=generate-a-random-64-char-secret-here
JWT_SECRET=generate-a-random-64-char-secret-here

# URLs
BACKEND_URL=http://localhost:8008

# Google OAuth
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# Web App (for OAuth redirect)
WEB_APP_URL=http://localhost:3008

# Debug
DEBUG=true
LOG_LEVEL=DEBUG
